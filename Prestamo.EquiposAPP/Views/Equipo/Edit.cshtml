@model Capa.Entidades.Equipo
@{
    ViewData["Title"] = "Editar Equipo";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card form-card shadow-lg">
                <div class="card-header edit-card-header text-center">
                    <h4 class="mb-0">⚙️ Editar Equipo #@Model.EquipoID</h4>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="EquipoID" value="@Model.EquipoID" />
                        <input type="hidden" name="Imagen" value="@Model.Imagen" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nombre del Equipo</label>
                            <input type="text" name="Nombre" class="form-control" value="@Model.Nombre" placeholder="Ej: Laptop HP" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Tipo</label>
                            <select name="Tipo" class="form-select">
                                <option value="Laptop" selected="@(Model.Tipo == "Laptop")">💻 Laptop</option>
                                <option value="Proyector" selected="@(Model.Tipo == "Proyector")">📽️ Proyector</option>
                                <option value="Monitor" selected="@(Model.Tipo == "Monitor")">🖥️ Monitor</option>
                                <option value="Parlante" selected="@(Model.Tipo == "Parlante")">🔊 Parlante</option>
                                <option value="Otros" selected="@(Model.Tipo == "Otros")">📦 Otros</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-danger">Estado Actual</label>
                            <select name="Estado" class="form-select border-danger">
                                <option value="Disponible" selected="@(Model.Estado == "Disponible")">Disponible</option>
                                <option value="Prestado" selected="@(Model.Estado == "Prestado")">Prestado</option>
                                <option value="Mantenimiento" selected="@(Model.Estado == "Mantenimiento")">Mantenimiento</option>
                            </select>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Imagen Actual</label>
                            <img src="@Model.Imagen" alt="@Model.Nombre" class="preview-img mb-3">
                            <label class="form-label fw-bold">Cambiar Imagen</label>
                            <input type="file" name="imagenArchivo" class="form-control" accept=".jpg,.jpeg,.png,.webp" />
                            <div class="form-text">Si no seleccionas una imagen nueva, se mantendra la actual.</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-update shadow-sm">
                                Guardar Cambios
                            </button>
                            <a href="/Equipo/Catalogo" class="btn btn-outline-secondary btn-back">
                                Volver al Catalogo
                            </a>
                        </div>
                    </form>

                    @if (ViewBag.mensaje != null)
                    {
                        <div class="alert alert-success mt-4 border-0 shadow-sm text-center" role="alert">
                            @ViewBag.mensaje
                        </div>
                    }
                </div>
            </div>
            <p class="text-center mt-4 text-muted small">&copy; 2025 - Sistema de prestamos de equipos tecnologicos</p>
        </div>
    </div>
</div>
