@model Capa.Entidades.Equipo
@{
    ViewData["Title"] = "Registro de Equipos";
}

<div class="container">
    <div class="row justify-content-center align-items-center" style="min-height: 90vh;">
        <div class="col-md-6">
            <div class="card form-card shadow-lg">
                <div class="card-header create-card-header text-white text-center">
                    <h3 class="mb-0">✨ Registro de Equipos</h3>
                    <p class="mb-0 opacity-75">Gestion 2025</p>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Crear" method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label">Nombre del Equipo</label>
                            <input asp-for="Nombre" name="Nombre" class="form-control" placeholder="Ej: Laptop ASUS Vivobook 15" required />
                            <div class="form-text text-muted">Escribe una marca y un modelo detallado.</div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Tipo de Equipo</label>
                            <select asp-for="Tipo" name="Tipo" class="form-select">
                                <option value="Laptop">💻 Laptop</option>
                                <option value="Proyector">📽️ Proyector</option>
                                <option value="Parlante">🔊 Parlante</option>
                                <option value="Monitor">🖥️ Monitor</option>
                                <option value="Otros">📦 Otros</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Imagen del Equipo</label>
                            <input type="file" name="imagenArchivo" class="form-control" accept=".jpg,.jpeg,.png,.webp" required />
                            <div class="form-text">Selecciona una imagen JPG, JPEG, PNG o WEBP desde tu equipo.</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success shadow-sm">
                                Guardar Equipo
                            </button>
                            <a href="/Equipo/Catalogo" class="btn btn-outline-secondary">
                                Volver al Listado
                            </a>
                        </div>
                    </form>

                    @if (ViewBag.mensaje != null)
                    {
                        <div class="alert alert-info alert-dismissible fade show mt-4 border-0 shadow-sm" role="alert">
                            <strong>Aviso:</strong> @ViewBag.mensaje
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }
                </div>
            </div>

            <p class="text-center mt-4 text-muted small">
                &copy; 2025 - Sistema de prestamos de equipos tecnologicos
            </p>
        </div>
    </div>
</div>
