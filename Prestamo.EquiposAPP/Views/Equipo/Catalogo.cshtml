@using Microsoft.AspNetCore.Http
@model IEnumerable<Capa.Entidades.Equipo>
@{
    ViewData["Title"] = "Catalogo de Equipos - Gestion 2025";
    string rol = Context.Session.GetString("UsuarioRol") ?? "";
    string nombre = Context.Session.GetString("UsuarioNombre") ?? "";
    string tipoSeleccionado = Context.Request.Query["tipoEquipo"].ToString();
}

<div class="container">
    <div class="main-card">
        <!-- ENCABEZADO -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 mb-0 text-primary">📋 Catalogo de Equipos</h1>
            <div class="d-flex align-items-center gap-3">
                <span class="text-dark small">👤 <strong>@nombre</strong> (@rol)</span>
                <a href="/Login/Logout" class="btn btn-outline-danger btn-sm">Cerrar Sesion</a>
            </div>
        </div>

        <!-- SECCIÓN DE API (Solo Dólar) -->
        <div class="row mb-4">
            <div class="col-md-4">
                <div class="card h-100 shadow-sm border-0" style="background-color: #e3f2fd; border-left: 5px solid #0d6efd !important;">
                    <div class="card-body d-flex align-items-center">
                        <div class="me-3 fs-1">💵</div>
                        <div>
                            <h6 class="mb-1 text-muted fw-bold" style="color: #495057 !important;">TIPO DE CAMBIO</h6>
                            <h4 class="mb-0 fw-bold" style="color: #0d6efd !important;">
                                S/ @(ViewBag.Dolar == "N/A" ? "3.75 (Simulado)" : ViewBag.Dolar)
                            </h4>
                            <small class="text-muted">USD a PEN</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- MENSAJES DE ALERTA -->
        @if (TempData["mensajeEliminar"] != null)
        {
            <div class="alert alert-info alert-dismissible fade show shadow-sm" role="alert">
                @TempData["mensajeEliminar"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- FILTROS Y BOTONES DE ACCIÓN -->
        <div class="filter-section p-3 bg-light rounded mb-4 border">
            <form method="get" action="/Equipo/Catalogo" class="row g-3 align-items-center">
                <div class="col-auto">
                    <label class="fw-bold text-dark">Filtrar por Categoría:</label>
                </div>
                <div class="col-md-4">
                    <select name="tipoEquipo" class="form-select border-primary" onchange="this.form.submit()">
                        <option value="Todos">Ver Todos</option>
                        <option value="Laptop" selected='@(tipoSeleccionado == "Laptop")'>💻 Laptops</option>
                        <option value="Monitor" selected='@(tipoSeleccionado == "Monitor")'>🖥️ Monitores</option>
                        <option value="Tablet" selected='@(tipoSeleccionado == "Tablet")'>📱 Tablets</option>
                        <option value="Parlante" selected='@(tipoSeleccionado == "Parlante")'>🔊 Parlantes</option>
                        <option value="Otros" selected='@(tipoSeleccionado == "Otros")'>📦 Otros</option>
                    </select>
                </div>
                <div class="col text-end">
                    @if (rol == "Administrador")
                    {
                        <a href="/Prestamo/Pendientes" class="btn btn-primary shadow-sm">Pendientes</a>
                        <a href="/Equipo/Crear" class="btn btn-success shadow-sm">+ Nuevo</a>
                    }
                    else
                    {
                        <!-- Botones para el Usuario: Se agregó Mis Solicitudes -->
                        <a href="/Prestamo/MisSolicitudes" class="btn btn-outline-primary shadow-sm me-2">Mis Solicitudes</a>
                        <a href="/Prestamo/Solicitar" class="btn btn-primary shadow-sm">Solicitar Préstamo</a>
                    }
                </div>
            </form>
        </div>

        <!-- TABLA DE EQUIPOS -->
        <div class="table-responsive shadow-sm rounded">
            <table class="table table-hover align-middle text-center bg-white mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>ID</th>
                        <th class="text-start">Nombre del Equipo</th>
                        <th>Tipo</th>
                        <th>Estado</th>
                        <th>Imagen</th>
                        @if (rol == "Administrador")
                        {
                            <th>Acciones</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="text-muted">#@item.EquipoID</td>
                            <td class="text-start fw-bold text-dark">@item.Nombre</td>
                            <td><span class="badge bg-outline-info text-dark border">@item.Tipo</span></td>
                            <td>
                                @if (item.Estado == "Disponible")
                                {
                                    <span class="badge bg-success">Disponible</span>
                                }
                                else if (item.Estado == "Prestado")
                                {
                                    <span class="badge bg-danger">En Uso</span>
                                }
                                else
                                {
                                    <span class="badge bg-warning text-dark">@item.Estado</span>
                                }
                            </td>
                            <td>
                                <img src="@item.Imagen" style="width:50px; height:50px; border-radius:5px; object-fit:cover;" class="border">
                            </td>
                            @if (rol == "Administrador")
                            {
                                <td>
                                    <a href="/Equipo/Edit/@item.EquipoID" class="btn btn-sm btn-warning">Editar</a>
                                    <a href="/Equipo/Eliminar/@item.EquipoID" class="btn btn-sm btn-danger" onclick="return confirm('¿Eliminar?')">X</a>
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>