@using Microsoft.AspNetCore.Http
@model IEnumerable<Capa.Entidades.Equipo>
@{
    ViewData["Title"] = "Solicitar Prestamo - Gestion 2025";
    string rol = Context.Session.GetString("UsuarioRol") ?? "";
    string nombre = Context.Session.GetString("UsuarioNombre") ?? "";
    string tipoSeleccionado = Context.Request.Query["tipoEquipo"].ToString();
}

<div class="container">
    <div class="main-card">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center">
                <h1 class="h3 mb-0 text-primary">📝 Solicitar Prestamo de Equipo</h1>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="text-muted small">👤 <strong>@nombre</strong> (@rol)</span>
                <a href="/Login/Logout" class="btn btn-outline-danger btn-sm">Cerrar Sesion</a>
            </div>
        </div>

        @if (TempData["mensaje"] != null)
        {
            var tipoAlerta = TempData["tipo"]?.ToString() ?? "info";
            <div class="alert alert-@tipoAlerta alert-dismissible fade show" role="alert">
                ✨ @TempData["mensaje"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="info-box">
            <h5 class="mb-3">ℹ️ Informacion Importante</h5>
            <ul class="mb-0">
                <li>Tu solicitud quedara en estado <strong>"Pendiente"</strong> hasta que un administrador la apruebe.</li>
                <li>La multa por retraso es de <strong>S/ 5.00 por dia</strong>.</li>
                <li>Asegurate de devolver el equipo en buen estado y en la fecha indicada.</li>
            </ul>
        </div>

        <div class="filter-section">
            <form method="get" action="/Prestamo/Solicitar" class="row g-3 align-items-center">
                <div class="col-auto">
                    <label class="fw-bold text-secondary">Filtrar por tipo:</label>
                </div>
                <div class="col-md-4">
                    <select name="tipoEquipo" class="form-select border-primary-subtle" onchange="this.form.submit()">
                        <option value="Todos">-- Todos --</option>
                        <option value="Laptop" selected='@(tipoSeleccionado == "Laptop")'>💻 Laptops</option>
                        <option value="Monitor" selected='@(tipoSeleccionado == "Monitor")'>🖥️ Monitores</option>
                        <option value="Tablet" selected='@(tipoSeleccionado == "Tablet")'>📱 Tablets</option>
                        <option value="Parlante" selected='@(tipoSeleccionado == "Parlante")'>🔊 Parlantes</option>
                        <option value="Otros" selected='@(tipoSeleccionado == "Otros")'>📦 Otros</option>
                    </select>
                </div>
                <div class="col text-end">
                    <a href="/Equipo/Catalogo" class="btn btn-secondary shadow-sm">
                        Volver al Catalogo
                    </a>
                </div>
            </form>
        </div>

        <form method="post" action="/Prestamo/Solicitar" id="formSolicitud">
            <div class="mb-4">
                <label class="form-label fw-bold fs-5">Selecciona un equipo disponible:</label>

                @if (Model.Any())
                {
                    <div class="row row-cols-1 row-cols-md-3 g-4 mt-2">
                        @foreach (var equipo in Model)
                        {
                            <div class="col">
                                <input type="radio"
                                       name="equipoID"
                                       value="@equipo.EquipoID"
                                       id="equipo_@equipo.EquipoID"
                                       class="equipo-radio"
                                       required />
                                <label for="equipo_@equipo.EquipoID" class="equipo-card p-3">
                                    <div class="text-center">
                                        @if (!string.IsNullOrEmpty(equipo.Imagen))
                                        {
                                            <img src="@equipo.Imagen" alt="@equipo.Nombre" class="img-fluid mb-3">
                                        }
                                        else
                                        {
                                            <div class="equipo-placeholder">
                                                <span class="placeholder-icon">Sin imagen</span>
                                            </div>
                                        }
                                        <h6 class="fw-bold mb-2">@equipo.Nombre</h6>
                                        <span class="badge bg-info mb-1">@equipo.Tipo</span>
                                        <br>
                                        <span class="badge bg-success">@equipo.Estado</span>
                                    </div>
                                </label>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="alert alert-warning mt-3">
                        <strong>No hay equipos disponibles en este momento.</strong>
                        <p class="mb-0 mt-2">Intenta con otra categoria o vuelve mas tarde.</p>
                    </div>
                }
            </div>

            @if (Model.Any())
            {
                <hr class="my-4">

                <div class="mb-4">
                    <label class="form-label fw-bold fs-5">Indica la fecha de devolucion estimada:</label>
                    <input type="date"
                           name="fechaFin"
                           class="form-control form-control-lg"
                           min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"
                           required />
                    <small class="form-text text-muted">
                        Selecciona la fecha en que planeas devolver el equipo.
                    </small>
                </div>

                <hr class="my-4">

                <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                    <a href="/Equipo/Catalogo" class="btn btn-secondary btn-lg px-5">
                        Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg px-5 shadow">
                        Registrar Solicitud
                    </button>
                </div>
            }
        </form>

        <footer class="text-center mt-5 text-muted small">
            <hr>
            &copy; 2025 - Sistema de prestamos de equipos tecnologicos
        </footer>
    </div>
</div>
