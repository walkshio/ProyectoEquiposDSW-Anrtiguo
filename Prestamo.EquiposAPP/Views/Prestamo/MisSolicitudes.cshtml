@using Microsoft.AspNetCore.Http
@model IEnumerable<Capa.Entidades.Prestamo>
@{
    ViewData["Title"] = "Mis Solicitudes - Gestion 2025";
    string rol = Context.Session.GetString("UsuarioRol") ?? "";
    string nombre = Context.Session.GetString("UsuarioNombre") ?? "";
}

<div class="container">
    <div class="main-card">

        ```
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center">
                <h1 class="h3 mb-0 text-primary">Mis Solicitudes</h1>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="text-muted small"><strong>@nombre</strong> (@rol)</span>
                <a href="/Login/Logout" class="btn btn-outline-danger btn-sm">Cerrar Sesion</a>
            </div>
        </div>

        @if (TempData["mensaje"] != null)
        {
            var tipo = TempData["tipo"]?.ToString() ?? "info";
            <div class="alert alert-@tipo alert-dismissible fade show" role="alert">
                @TempData["mensaje"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="info-section d-flex justify-content-between align-items-center">
            <div>
                <strong>Seguimiento de prestamos</strong>
                <div class="text-muted small">Revisa si tus solicitudes estan pendientes, aprobadas o rechazadas.</div>
            </div>
            <div class="d-flex gap-2">
                <a href="/Prestamo/Solicitar" class="btn btn-primary shadow-sm">Nueva Solicitud</a>
                <a href="/Equipo/Catalogo" class="btn btn-secondary shadow-sm">Volver al Catalogo</a>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-warning">
                Todavia no tienes solicitudes registradas.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle text-center">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th class="text-start">Equipo</th>
                            <th>Tipo</th>
                            <th>Fecha solicitud</th>
                            <th>Fecha devolucion</th>
                            <th>Estado</th>
                            <th>Multa</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-muted">#@item.PrestamoID</td>
                                <td class="text-start fw-semibold">@item.NombreEquipo</td>
                                <td><span class="badge bg-info text-dark">@item.TipoEquipo</span></td>
                                <td>@item.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                                <td>@item.FechaFin.ToString("dd/MM/yyyy")</td>

                                <td>
                                    @if (item.Estado == "Pendiente")
                                    {
                                        <span class="badge bg-warning text-dark">Pendiente</span>
                                    }
                                    else if (item.Estado == "Aprobado")
                                    {
                                        <span class="badge bg-success">Aprobado</span>
                                    }
                                    else if (item.Estado == "Rechazado")
                                    {
                                        <span class="badge bg-danger">Rechazado</span>
                                    }
                                    else if (item.Estado == "EnUso")
                                    {
                                        <span class="badge bg-primary">En uso</span>
                                    }
                                    else if (item.Estado == "Devuelto")
                                    {
                                        <span class="badge bg-secondary">Devuelto</span>
                                    }
                                </td>

                                <td>S/ @item.Multa.ToString("0.00")</td>

                                <td>
                                    @if (item.Estado == "Aprobado")
                                    {
                                        <div class="d-flex flex-column gap-1">
                                            <a href="/Prestamo/ConfirmarEntrega/@item.PrestamoID"
                                                   class="btn btn-success btn-sm">
                                                ✔ Entregado
                                            </a>

                                            <a href="/Prestamo/NoEntregado"
                                                   class="btn btn-warning btn-sm">
                                                ✖ No entregado
                                            </a>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <footer class="text-center mt-4 text-muted small">
            <hr>
            &copy; 2025 - Sistema de prestamos de equipos tecnologicos
        </footer>

    </div>
    ```

</div>
