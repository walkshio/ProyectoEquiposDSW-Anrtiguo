@using Microsoft.AspNetCore.Http
@model IEnumerable<Capa.Entidades.Prestamo>
@{
    ViewData["Title"] = "Solicitudes Pendientes - Gestion 2025";
    string rol = Context.Session.GetString("UsuarioRol") ?? "";
    string nombre = Context.Session.GetString("UsuarioNombre") ?? "";
}

<div class="container">
    <div class="main-card">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div class="d-flex align-items-center">
                <h1 class="h3 mb-0 text-primary">Solicitudes Pendientes</h1>
            </div>
            <div class="d-flex align-items-center gap-3">
                <span class="text-muted small"><strong>@nombre</strong> (@rol)</span>
                <a href="/Login/Logout" class="btn btn-outline-danger btn-sm">Cerrar Sesion</a>
            </div>
        </div>

        @if (TempData["mensaje"] != null)
        {
            var tipoAlerta = TempData["tipo"]?.ToString() ?? "info";
            <div class="alert alert-@tipoAlerta alert-dismissible fade show" role="alert">
                @TempData["mensaje"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <div class="info-section d-flex justify-content-between align-items-center">
            <div>
                <strong>Evaluacion de solicitudes</strong>
                <div class="text-muted small">Aprueba o rechaza las solicitudes registradas por los usuarios.</div>
            </div>
            <div class="d-flex gap-2">
                <a href="/Prestamo/EnUso" class="btn btn-primary">
                    Ver equipos en uso
                </a>
                <a href="/Equipo/Catalogo" class="btn btn-secondary shadow-sm">
                    Volver al Catalogo
                </a>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="alert alert-warning">
                No hay solicitudes pendientes para evaluar.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle text-center">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th class="text-start">Equipo</th>
                            <th>Tipo</th>
                            <th class="text-start">Usuario</th>
                            <th>Correo</th>
                            <th>Fecha solicitud</th>
                            <th>Fecha devolucion</th>
                            <th>Estado</th>
                            <th width="180">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="text-muted">#@item.PrestamoID</td>
                                <td class="text-start fw-semibold">@item.NombreEquipo</td>
                                <td><span class="badge bg-info text-dark">@item.TipoEquipo</span></td>
                                <td class="text-start">@item.NombreUsuario</td>
                                <td>@item.CorreoUsuario</td>
                                <td>@item.FechaSolicitud.ToString("dd/MM/yyyy")</td>
                                <td>@item.FechaFin.ToString("dd/MM/yyyy")</td>
                                <td><span class="badge bg-warning text-dark">@item.Estado</span></td>
                                <td>
                                    <div class="d-flex justify-content-center gap-2">
                                        @if (item.Estado == "Pendiente")
                                        {
                                            <a href="/Prestamo/Aprobar/@item.PrestamoID"
                                               class="btn btn-success btn-sm">Aprobar</a>
                                            <a href="/Prestamo/Rechazar/@item.PrestamoID"
                                               class="btn btn-danger btn-sm">Rechazar</a>
                                        }
                                        else if (item.Estado == "Aprobado")
                                        {
                                            <a href="/Prestamo/Entregar/@item.PrestamoID"
                                               class="btn btn-primary btn-sm">Entregar</a>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <footer class="text-center mt-4 text-muted small">
            <hr>
            &copy; 2025 - Sistema de prestamos de equipos tecnologicos
        </footer>
    </div>
</div>